{
  "manifest_version": 3,
  "name": "MA Styled — Hope Core",
  "version": "0.1.0",
  "description": "Pointillist futurist theme for Math Academy — the dawn rises as you learn.",
  "permissions": ["storage"],
  "background": {
    "service_worker": "src/background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.mathacademy.com/learn*",
        "*://*.mathacademy.com/courses/*"
      ],
      "css": ["src/theme.css"],
      "js": ["src/early.js"],
      "run_at": "document_start"
    },
    {
      "matches": [
        "*://*.mathacademy.com/learn*",
        "*://*.mathacademy.com/courses/*"
      ],
      "js": ["src/content.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["fonts/*.woff2"],
      "matches": ["*://*.mathacademy.com/*"]
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "MA Styled"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
